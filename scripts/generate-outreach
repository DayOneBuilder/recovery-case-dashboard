#!/usr/bin/env node
"use strict";

const fs = require("fs");
const path = require("path");
const vm = require("vm");

const repoRoot = path.resolve(__dirname, "..");
const registryPath = path.join(repoRoot, "config", "cases.json");
const args = process.argv.slice(2);

function usage(exitCode = 0) {
  const stream = exitCode ? process.stderr : process.stdout;
  stream.write(`Usage:
  scripts/generate-outreach --list [case-id]
  scripts/generate-outreach [case-id] <outreach-id> [--stdout] [--force]

Examples:
  scripts/generate-outreach --list
  scripts/generate-outreach ciotx-iotex-status-request
  scripts/generate-outreach iotex-iotube ciotx-iotex-status-request --stdout
`);
  process.exit(exitCode);
}

function fail(message) {
  console.error(`generate-outreach: ${message}`);
  process.exit(1);
}

function asArray(value) {
  return Array.isArray(value) ? value : [];
}

function loadCaseData(filePath) {
  const code = fs.readFileSync(filePath, "utf8");
  const context = { window: {} };
  vm.createContext(context);
  vm.runInContext(code, context, { filename: filePath });
  return context.window.RECOVERY_CASE;
}

function findCase(registry, caseId) {
  const entry = asArray(registry.cases).find((item) => item.id === caseId);
  if (!entry) fail(`unknown case '${caseId}'`);
  return entry;
}

function safeOutputPath(value, fallback) {
  const target = value || fallback;
  if (
    typeof target !== "string" ||
    !target ||
    target.includes("://") ||
    target.startsWith("/") ||
    target.includes("..")
  ) {
    fail(`unsafe output path '${target}'`);
  }
  return path.join(repoRoot, target);
}

function oneLine(value) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

function sourceMarkdown(caseData, refs) {
  const sourceById = new Map(asArray(caseData.sources).map((source) => [source.id, source]));
  return asArray(refs)
    .map((ref) => sourceById.get(ref))
    .filter(Boolean)
    .map((source) => `- ${source.label}: ${source.url}`)
    .join("\n");
}

function packetPageUrl(publicUrl, packetFile) {
  if (!packetFile) return publicUrl;
  return `${publicUrl}packet.html?file=${encodeURIComponent(packetFile)}`;
}

function buildDraft(caseData, item) {
  const opportunityById = new Map(
    asArray(caseData.recoveryOpportunities).map((entry) => [entry.id, entry]),
  );
  const contactById = new Map(asArray(caseData.contacts).map((entry) => [entry.id, entry]));
  const packetById = new Map(
    asArray(caseData.recoveryPackets).map((entry) => [entry.id, entry]),
  );

  const opportunity = opportunityById.get(item.opportunityRef);
  const contact = contactById.get(item.contactRef);
  const packet = packetById.get(item.packetRef);

  if (!opportunity) fail(`outreach '${item.id}' references missing opportunity`);
  if (!contact) fail(`outreach '${item.id}' references missing contact`);
  if (!packet) fail(`outreach '${item.id}' references missing packet`);

  const caseInfo = caseData.case || {};
  const publicUrl = caseInfo.publicUrl || "";
  const packetUrl = packetPageUrl(publicUrl, packet.packetFile);
  const subject = `Public-source recovery lead: ${caseInfo.victim || caseInfo.title} / ${item.title}`;

  return `# Outreach Draft: ${item.title}

Status: ${item.status}
Case: ${caseInfo.title || caseData.id}
Contact route: ${contact.name}
Channel: ${contact.channel}
Generated by: scripts/generate-outreach

Do not send automatically. Review the evidence packet, current balances, and recipient route before sending.

## Subject

${subject}

## Email Body

Hello ${contact.organization || "team"} team,

I am sharing a public-source recovery lead related to ${caseInfo.victim || caseInfo.title}.

I am an independent researcher acting in good faith. I am not requesting access to funds, private systems, non-public victim data, or account information. The goal is to help route actionable recovery intelligence to the right team.

Current lead:

- Opportunity: ${opportunity.title}
- Value at stake: ${item.valueAtStake}
- Current ask: ${contact.nextAsk}
- Evidence packet: ${packetUrl}
- Public dashboard: ${publicUrl}

Why I am contacting you now:

${item.whyContactNow}

What I am asking for:

1. Please confirm whether this is the correct route for this recovery intelligence.
2. Please assign a case/reference ID if this should be tracked formally.
3. Please confirm whether the described funds or venue branch are already frozen, preserved, settled, or otherwise handled.
4. Please tell me what additional public-source evidence would be useful and safe to provide.

Reward / attribution position:

I am providing the lead in good faith and value-first. If information from this investigation materially contributes to asset recovery, preservation, enforcement action, or identification of responsible parties, I would appreciate being considered for standard researcher credit and any applicable recovery, bounty, or intelligence reward process.

I will avoid publishing sensitive operational details while your team reviews.

Best regards,
[YOUR NAME]
[YOUR CONTACT]

## Claim Boundary

${oneLine(opportunity.blockers ? opportunity.blockers.join("; ") : packet.missing?.join("; "))}

## Send Condition

${item.sendCondition}

## Reward Protection

${item.rewardProtection}

## Sources

${sourceMarkdown(caseData, item.evidenceRefs)}
`;
}

const registry = JSON.parse(fs.readFileSync(registryPath, "utf8"));
const knownCaseIds = new Set(asArray(registry.cases).map((entry) => entry.id));
const listMode = args.includes("--list");
const stdoutMode = args.includes("--stdout");
const forceMode = args.includes("--force");
const positional = args.filter((arg) => !arg.startsWith("--"));

if (args.includes("--help") || args.includes("-h")) usage(0);

let caseId = registry.defaultCaseId;
let outreachId = "";

if (positional[0] && knownCaseIds.has(positional[0])) {
  caseId = positional[0];
  outreachId = positional[1] || "";
} else if (positional[0]) {
  outreachId = positional[0];
}

const caseConfig = findCase(registry, caseId);
const caseData = loadCaseData(path.join(repoRoot, caseConfig.dataFile));

if (listMode) {
  for (const item of asArray(caseData.outreachQueue)) {
    console.log(`${item.id}\t${item.status}\t${item.title}`);
  }
  process.exit(0);
}

if (!outreachId) usage(1);

const item = asArray(caseData.outreachQueue).find((entry) => entry.id === outreachId);
if (!item) fail(`unknown outreach id '${outreachId}'`);

const draft = buildDraft(caseData, item);

if (stdoutMode) {
  process.stdout.write(draft);
  process.exit(0);
}

const outputPath = safeOutputPath(
  item.latestDraft,
  `outreach/drafts/${caseId}-${item.id}.md`,
);

if (fs.existsSync(outputPath) && !forceMode) {
  fail(`draft exists: ${path.relative(repoRoot, outputPath)} (use --force)`);
}

fs.mkdirSync(path.dirname(outputPath), { recursive: true });
fs.writeFileSync(outputPath, draft, "utf8");
console.log(`generate-outreach: wrote ${path.relative(repoRoot, outputPath)}`);

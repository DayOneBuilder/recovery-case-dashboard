#!/usr/bin/env python3
"""Queue an OpenClaw cron refresh for a configured recovery case."""

from __future__ import annotations

import json
import subprocess
import sys
from datetime import datetime, timezone
from json import JSONDecodeError
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
REGISTRY_PATH = REPO_ROOT / "config" / "cases.json"
FALLBACK_DEFAULT_CASE_ID = "iotex-iotube"
DEFAULT_AGENT_TIMEOUT_SECONDS = 1200
FALLBACK_LOG_DIR = Path("/tmp/case-refresh")


def fail(message: str, exit_code: int = 1) -> None:
    print(f"case-refresh: {message}", file=sys.stderr)
    raise SystemExit(exit_code)


def usage() -> str:
    return (
        "Usage: scripts/case-refresh [case-id]\n"
        "       scripts/case-refresh --list\n"
        "\n"
        f"Default case id: {FALLBACK_DEFAULT_CASE_ID}"
    )


def load_registry() -> tuple[str, dict[str, dict[str, Any]]]:
    try:
        registry = json.loads(REGISTRY_PATH.read_text(encoding="utf-8"))
    except FileNotFoundError:
        fail(f"missing registry file: {REGISTRY_PATH.relative_to(REPO_ROOT)}")
    except JSONDecodeError as exc:
        fail(f"invalid registry JSON at {REGISTRY_PATH.relative_to(REPO_ROOT)}: {exc}")

    raw_cases = registry.get("cases")
    if not isinstance(raw_cases, list):
        fail("registry field 'cases' must be a list")

    cases: dict[str, dict[str, Any]] = {}
    for raw_case in raw_cases:
        if not isinstance(raw_case, dict):
            fail("registry case entries must be objects")

        case_id = raw_case.get("id")
        cron_job_name = raw_case.get("cronJobName")
        if not isinstance(case_id, str) or not case_id:
            fail("registry case entry is missing string field 'id'")
        if not isinstance(cron_job_name, str) or not cron_job_name:
            fail(f"registry case '{case_id}' is missing string field 'cronJobName'")
        if case_id in cases:
            fail(f"duplicate case id in registry: {case_id}")

        cases[case_id] = raw_case

    default_case_id = registry.get("defaultCaseId", FALLBACK_DEFAULT_CASE_ID)
    if not isinstance(default_case_id, str) or not default_case_id:
        fail("registry field 'defaultCaseId' must be a non-empty string")

    return default_case_id, cases


def print_cases(cases: dict[str, dict[str, Any]]) -> None:
    print("Configured cases:")
    for case_id in sorted(cases):
        case = cases[case_id]
        title = case.get("title", case_id)
        print(f"- {case_id}: {title} -> {case['cronJobName']}")


def require_case_string(case_id: str, case: dict[str, Any], field: str) -> str:
    value = case.get(field)
    if not isinstance(value, str) or not value.strip():
        fail(f"registry case '{case_id}' is missing string field '{field}'")
    return value.strip()


def resolve_repo_path(case_id: str, relative_path: str, field: str) -> Path:
    path = (REPO_ROOT / relative_path).resolve()
    try:
        path.relative_to(REPO_ROOT)
    except ValueError:
        fail(f"registry case '{case_id}' field '{field}' points outside the repo: {relative_path}")
    return path


def extract_json_payload(text: str) -> Any:
    decoder = json.JSONDecoder()
    fallback: Any = None

    for index, char in enumerate(text):
        if char not in "[{":
            continue
        try:
            payload, _ = decoder.raw_decode(text[index:])
        except JSONDecodeError:
            continue

        if isinstance(payload, dict) and "jobs" in payload:
            return payload
        if isinstance(payload, list):
            return {"jobs": payload}
        if fallback is None:
            fallback = payload

    if fallback is not None:
        return fallback
    fail("could not find a JSON payload in OpenClaw stdout")


def run_command(command: list[str]) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(command, capture_output=True, text=True, check=False)
    except FileNotFoundError:
        fail(f"command not found: {command[0]}")


def summarize_failure(result: subprocess.CompletedProcess[str]) -> str:
    return result.stderr.strip() or result.stdout.strip() or "no output"


def list_openclaw_crons() -> list[dict[str, Any]]:
    result = run_command(["openclaw", "cron", "list", "--json"])
    if result.returncode != 0:
        detail = result.stderr.strip() or result.stdout.strip() or "no output"
        fail(f"'openclaw cron list --json' failed with exit {result.returncode}: {detail}")

    payload = extract_json_payload(result.stdout)
    jobs = payload.get("jobs") if isinstance(payload, dict) else None
    if not isinstance(jobs, list):
        fail("OpenClaw JSON did not contain a 'jobs' list")

    normalized_jobs: list[dict[str, Any]] = []
    for job in jobs:
        if isinstance(job, dict):
            normalized_jobs.append(job)
    return normalized_jobs


def find_cron_job(jobs: list[dict[str, Any]], cron_job_name: str) -> dict[str, Any] | None:
    for job in jobs:
        if job.get("name") == cron_job_name:
            return job
    return None


def available_job_names(jobs: list[dict[str, Any]]) -> str:
    names = sorted(job["name"] for job in jobs if isinstance(job.get("name"), str))
    if not names:
        return "none"
    return ", ".join(names[:12]) + (" ..." if len(names) > 12 else "")


def enqueue_cron_run(job_id: str) -> subprocess.CompletedProcess[str]:
    return run_command(["openclaw", "cron", "run", job_id])


def build_refresh_prompt(case_id: str, case: dict[str, Any]) -> str:
    data_file_raw = require_case_string(case_id, case, "dataFile")
    workflow_raw = require_case_string(case_id, case, "refreshWorkflow")
    notify_channel = require_case_string(case_id, case, "notifyChannel")
    notify_target = require_case_string(case_id, case, "notifyTarget")
    notify_thread_id = require_case_string(case_id, case, "notifyThreadId")

    data_file = resolve_repo_path(case_id, data_file_raw, "dataFile")
    workflow_file = resolve_repo_path(case_id, workflow_raw, "refreshWorkflow")
    readme_file = REPO_ROOT / "README.md"

    return (
        f"Incremental refresh for recovery case `{case_id}`.\n\n"
        f"Repo: {REPO_ROOT}\n"
        f"Primary data file: {data_file}\n"
        f"Workflow file: {workflow_file}\n"
        f"README: {readme_file}\n\n"
        "This is NOT a fresh research task. Validate the CURRENT known public state and add only material deltas.\n\n"
        "Rules:\n"
        "- Read the workflow file first, then README and the case data file.\n"
	        "- Check only the already-known branches, addresses, venues, balances, dates, actions, classifications, and source-backed claims already present in the case.\n"
	        "- Do not widen scope unless a targeted check shows a confirmed material change.\n"
	        "- If nothing material changed, do not edit files and do not create a commit.\n"
	        "- Do not commit volatile service-cluster counters by themselves, including tx count, lifetime funded volume, crawler-derived cluster size, or explorer rendering changes.\n"
	        "- Do not commit repeated internal service-cluster churn txs unless they create a new venue, freeze target, stronger attribution, or other recovery hook.\n"
	        "- Commit only if the delta affects recovery actionability: tracked stolen-tail movement, balance/freeze/blacklist/venue status, confirmed landing, attribution confidence, disproven claim, score/action, timeline, or source list.\n"
	        "- Prioritize recovery hooks over trace volume: update recoveryCommand, recoveryOpportunities, contacts, outreachQueue, authorities, or recoveryPackets only when the action path changes.\n"
	        "- If an outreach item changes, regenerate its draft with scripts/generate-outreach <outreach-id> --force.\n"
	        "- Never send external outreach automatically; prepare drafts and report what needs user approval.\n"
	        "- If material changes are confirmed, update only the necessary parts of the case file and keep the existing schema and public-claim boundaries intact.\n"
	        "- After edits, run scripts/validate-case and a lightweight sanity check so the case JS still parses and exposes window.RECOVERY_CASE.\n"
        f"- If repo files changed, run git status, commit with: Refresh case state: {case_id}, then git push origin main.\n"
        f"- Then send a concise update yourself via the message tool to channel={notify_channel}, target={notify_target}, threadId={notify_thread_id}.\n"
        "- When using the message tool, pass only action=send, channel=slack, target, threadId, and message. Do not set blocks, interactive, buttons, or other optional Slack fields.\n"
        "- Slack update format:\n"
        f"  1) first line exactly one of: Проверил {case_id}, изменений нет. OR Обновил {case_id}.\n"
        "  2) then 2-5 short bullets with the exact deltas or exact re-validation points\n"
        "  3) if a commit was created, include the short hash in the message\n"
        "- After sending the Slack message, return exactly NO_REPLY."
    )


def launch_direct_agent_refresh(case_id: str, case: dict[str, Any]) -> tuple[subprocess.Popen[str], Path]:
    prompt = build_refresh_prompt(case_id, case)
    FALLBACK_LOG_DIR.mkdir(parents=True, exist_ok=True)
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    log_path = FALLBACK_LOG_DIR / f"{case_id}-{timestamp}.log"

    with log_path.open("w", encoding="utf-8") as log_file:
        process = subprocess.Popen(
            [
                "openclaw",
                "agent",
                "--agent",
                "main",
                "--message",
                prompt,
                "--timeout",
                str(DEFAULT_AGENT_TIMEOUT_SECONDS)
            ],
            stdout=log_file,
            stderr=subprocess.STDOUT,
            text=True,
            start_new_session=True
        )

    return process, log_path


def parse_args(argv: list[str]) -> tuple[bool, str | None]:
    if len(argv) > 2:
        fail(f"too many arguments\n{usage()}", exit_code=2)

    if argv and argv[0] in {"-h", "--help"}:
        print(usage())
        raise SystemExit(0)
    if argv and argv[0] == "--list":
        if len(argv) > 1:
            fail("--list does not accept a case id", exit_code=2)
        return True, None
    if argv and argv[0].startswith("-"):
        fail(f"unknown option: {argv[0]}\n{usage()}", exit_code=2)

    return False, argv[0] if argv else None


def main(argv: list[str]) -> int:
    should_list, requested_case_id = parse_args(argv)
    default_case_id, cases = load_registry()

    if should_list:
        print_cases(cases)
        return 0

    case_id = requested_case_id or default_case_id
    case = cases.get(case_id)
    if case is None:
        known = ", ".join(sorted(cases)) or "none"
        fail(f"unknown case id '{case_id}'. Known cases: {known}")

    cron_job_name = require_case_string(case_id, case, "cronJobName")
    jobs = list_openclaw_crons()
    job = find_cron_job(jobs, cron_job_name)

    cron_error: str | None = None
    if job is not None:
        job_id = job.get("id")
        if not isinstance(job_id, str) or not job_id:
            fail(f"cron job '{cron_job_name}' is missing an id")

        cron_result = enqueue_cron_run(job_id)
        if cron_result.returncode == 0:
            print(f"Queued refresh for case '{case_id}'.")
            print(f"Mode: cron")
            print(f"Cron job: {cron_job_name}")
            print(f"Job id: {job_id}")
            return 0

        cron_error = f"manual cron trigger failed: {summarize_failure(cron_result)}"
    else:
        cron_error = (
            f"cron job '{cron_job_name}' was not found. "
            f"Available jobs: {available_job_names(jobs)}"
        )

    try:
        process, log_path = launch_direct_agent_refresh(case_id, case)
    except OSError as exc:
        fail(f"{cron_error}\ndirect agent fallback could not be started: {exc}")

    print(f"Triggered refresh for case '{case_id}'.")
    print("Mode: direct-agent-fallback")
    print("Result delivery: configured Slack thread via message tool")
    print(f"Background pid: {process.pid}")
    print(f"Log: {log_path}")
    if cron_error:
        print(f"Note: {cron_error}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
